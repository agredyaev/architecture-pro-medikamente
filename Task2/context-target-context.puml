System_Ext(channels, "Внешние каналы уведомлений", "SMS, e-mail, push и voice")

Rel(patient, opsPlatform, "Самозапись, подтверждение, отмена и self-service")
Rel(reception, opsPlatform, "Запись, профиль и обработка подтверждений")
